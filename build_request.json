{
  "source": {
    "storageSource": {
      "bucket": "run-sources-promptwars-mumbai-499305-asia-south1",
      "object": "carbon-canvas-source-v7.tar.gz"
    }
  },
  "steps": [
    {
      "name": "gcr.io/cloud-builders/docker",
      "args": ["build", "-t", "gcr.io/promptwars-mumbai-499305/carbon-canvas", "."]
    },
    {
      "name": "gcr.io/cloud-builders/docker",
      "args": ["push", "gcr.io/promptwars-mumbai-499305/carbon-canvas"]
    },
    {
      "name": "gcr.io/cloud-builders/gcloud",
      "args": [
        "run", "deploy", "carbon-canvas",
        "--image=gcr.io/promptwars-mumbai-499305/carbon-canvas",
        "--region=asia-south1",
        "--platform=managed",
        "--allow-unauthenticated",
        "--memory=256Mi",
        "--min-instances=0",
        "--max-instances=1",
        "--timeout=5m",
        "--set-env-vars=OPENROUTER_API_KEY=PLACEHOLDER_REPLACE_ME"
      ]
    }
  ],
  "images": ["gcr.io/promptwars-mumbai-499305/carbon-canvas"]
}
